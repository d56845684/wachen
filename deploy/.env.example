# 本檔已被 .gitignore 排除，絕不進版控。
# 提醒：此 key 曾出現於對話中，PoC 結束後請至 Google AI Studio 重新產生。
POSTGRES_PASSWORD=wachen_dev

GEMINI_API_KEY=
# 2.5-flash-lite：2.5 系列最便宜，分類/情緒任務足夠；要更高品質改 gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash-lite

# 瓦城 Places 爬取（scripts/crawl_wacheng_places.py）
GOOGLE_PLACES_API_KEY=
WACHEN_PLACES_WEBHOOK_SECRET=

# 後台管理員帳密（由 API 啟動時建立；未設定則無法登入）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Wachen!2026

# mobile app 的 API base（make mobile 讀取；留空 → app 走內建 mock 離線 demo）
# iOS 模擬器: http://127.0.0.1:8088   Android 模擬器: http://10.0.2.2:8088
# 真機: make tunnel ARGS=start 拿到的 https://xxx.trycloudflare.com
EXPO_PUBLIC_API_URL=

# 事件層驅動：nats（預設，docker-compose）或 sqs（AWS 正式環境）
# sqs 模式需 AWS 憑證鏈（IAM role / AWS_ACCESS_KEY_ID）+ 下列佇列 URL
# （deploy/aws/ Terraform 部署時由 ECS/EC2 自動注入，本機不用填）
QUEUE_DRIVER=nats
#AWS_REGION=ap-northeast-1
#SQS_CRAWL_JOBS_URL=
#SQS_REVIEW_RAW_URL=
#SQS_REVIEW_CREATED_URL=
#SQS_REVIEW_ANALYZED_URL=
#SQS_CASE_CREATED_URL=
#SQS_REPLY_REQUESTED_URL=
